YUANQI_API_BASE=http://127.0.0.1:8080/api/v1
# On-demand ISR invalidation (YuanQiService seo.revalidate_* must match)
REVALIDATE_SECRET=dev-revalidate-secret
# Local app + auth (SEO dev on :3002, webapp dev on :3000)
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_YUANQI_API_BASE=http://localhost:3000/api/v1
# Category directory uses YuanQiService /seo/categories/directory (DigiKey native L1 + ES counts).
# Set to true only for offline UI work without the API.
# USE_MOCK_CATEGORY_DIRECTORY=true
# Legacy marketing hub mock for /dev/seo-previews only:
# USE_MOCK_CATEGORY_HUB=true
# Flagship manufacturer design samples (default off in production):
# USE_MOCK_MANUFACTURER_PAGES=true
# USE_MOCK_COMPONENT_PAGES=true
# Optional: when testing merged robots without CF Worker (production uses Worker instead)
# WEBFLOW_SITEMAP_URL=https://www.partgenie.ai/sitemap.xml
# Optional: nav Tools/Pricing/Compare → Webflow until those pages ship on SeoWeb (default https://www.partgenie.ai)
# NEXT_PUBLIC_NAV_WEBFLOW_ORIGIN=https://www.partgenie.ai
# NEXT_PUBLIC_APP_ORIGIN=https://app.partgenie.ai
# NEXT_PUBLIC_YUANQI_API_BASE=https://app.partgenie.ai/api/v1
